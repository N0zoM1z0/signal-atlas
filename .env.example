# Signal Atlas defaults to deterministic, network-free Pref fixtures.
SIGNAL_ATLAS_PREF_MODE=fixture

# Live mode accepts only the allow-listed HTTPS /mcp endpoint. Keep the bearer blank in files;
# provide it to the orchestrator process from a secret manager or an interactive shell.
SIGNAL_ATLAS_PREF_URL=https://pref.trade/mcp
SIGNAL_ATLAS_PREF_BEARER_TOKEN=
