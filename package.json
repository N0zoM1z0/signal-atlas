{
  "name": "signal-atlas",
  "version": "0.0.0",
  "private": true,
  "description": "A local-first pixel-world interface for evidence-grounded forecasting.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "predev": "pnpm --recursive --filter './packages/**' --if-present build",
    "dev": "concurrently --kill-others-on-fail --names orchestrator,web --prefix-colors yellow,cyan \"pnpm --filter @signal-atlas/orchestrator dev\" \"pnpm --filter @signal-atlas/web dev\"",
    "build": "pnpm --recursive --if-present build",
    "build:pages": "pnpm --filter @signal-atlas/web build:pages",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --recursive --if-present test",
    "test:e2e": "playwright test --grep-invert '@visual|@soak'",
    "test:pages": "pnpm build:pages && playwright test --config playwright.pages.config.ts",
    "test:soak": "SIGNAL_ATLAS_RUN_SOAK=1 playwright test tests/e2e/long-session.spec.ts",
    "test:visual": "playwright test --grep @visual",
    "clean": "pnpm --recursive --if-present clean"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
