{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-atlas.local/schemas/world-manifest.schema.json",
  "title": "Signal Atlas World Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "template",
    "logicalWidth",
    "logicalHeight",
    "tileSize",
    "places",
    "routes",
    "defaultSpawnPlaceId",
    "assetPack"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "template": {
      "type": "string"
    },
    "logicalWidth": {
      "type": "integer",
      "minimum": 1
    },
    "logicalHeight": {
      "type": "integer",
      "minimum": 1
    },
    "tileSize": {
      "type": "integer",
      "enum": [
        8,
        16,
        24,
        32
      ]
    },
    "places": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/place"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      }
    },
    "ambientLayers": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "cameraZones": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "defaultSpawnPlaceId": {
      "type": "string"
    },
    "assetPack": {
      "type": "string"
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "archetype",
        "position",
        "entranceNodeId",
        "description",
        "missionVerbs",
        "capabilityBindings",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "archetype": {
          "enum": [
            "observatory",
            "newsroom",
            "weather_tower",
            "exchange",
            "archive",
            "professor",
            "town_square",
            "field_site"
          ]
        },
        "position": {
          "$ref": "#/$defs/point"
        },
        "entranceNodeId": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "missionVerbs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "capabilityBindings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "visualState": {
          "type": "object"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fromPlaceId",
        "toPlaceId",
        "waypoints",
        "baseDurationMs",
        "bidirectional",
        "transitType"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "fromPlaceId": {
          "type": "string"
        },
        "toPlaceId": {
          "type": "string"
        },
        "waypoints": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/point"
          }
        },
        "baseDurationMs": {
          "type": "integer",
          "minimum": 0
        },
        "bidirectional": {
          "type": "boolean"
        },
        "transitType": {
          "enum": [
            "walk",
            "tram",
            "boat",
            "elevator"
          ]
        },
        "cameraHint": {
          "enum": [
            "follow",
            "wide",
            "none"
          ]
        }
      }
    }
  }
}
