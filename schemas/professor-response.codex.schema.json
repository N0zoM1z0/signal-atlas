{
  "$comment": "Generated by @signal-atlas/contracts. Edit the Zod source and rerun pnpm --filter @signal-atlas/contracts generate:schemas. This strict transport projection is generated from packages/contracts/scripts/codex-output-schema.ts.",
  "$defs": {
    "entityId": {
      "maxLength": 160,
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$",
      "type": "string"
    },
    "evidence": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/entityId"
        },
        "type": {
          "enum": [
            "source",
            "signal"
          ],
          "type": "string"
        }
      },
      "required": [
        "type",
        "id"
      ],
      "type": "object"
    },
    "missionProposal": {
      "additionalProperties": false,
      "properties": {
        "destinationPlaceId": {
          "anyOf": [
            {
              "$ref": "#/$defs/entityId"
            },
            {
              "type": "null"
            }
          ]
        },
        "objective": {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string"
        },
        "verb": {
          "enum": [
            "investigate",
            "verify",
            "search_history",
            "find_contradiction",
            "compare_sources",
            "observe_conditions",
            "meet_agent",
            "deliver_signal",
            "reassess_forecast",
            "consult_professor"
          ],
          "type": "string"
        }
      },
      "required": [
        "verb",
        "objective",
        "destinationPlaceId"
      ],
      "type": "object"
    },
    "professorMode": {
      "enum": [
        "explain",
        "challenge",
        "compare",
        "base_rate",
        "missing_evidence",
        "correlation_check",
        "forecast_impact"
      ],
      "type": "string"
    }
  },
  "$id": "https://signal-atlas.local/schemas/professor-response.codex.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "answer": {
      "maxLength": 2000,
      "minLength": 1,
      "type": "string"
    },
    "assumptions": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 8,
      "type": "array"
    },
    "evidenceUsed": {
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "maxItems": 512,
      "type": "array"
    },
    "limitations": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 8,
      "type": "array"
    },
    "mode": {
      "$ref": "#/$defs/professorMode"
    },
    "queryId": {
      "$ref": "#/$defs/entityId"
    },
    "selectedSignalIds": {
      "items": {
        "$ref": "#/$defs/entityId"
      },
      "maxItems": 256,
      "type": "array"
    },
    "suggestedMission": {
      "anyOf": [
        {
          "$ref": "#/$defs/missionProposal"
        },
        {
          "type": "null"
        }
      ]
    },
    "suggestedNextQuestion": {
      "anyOf": [
        {
          "maxLength": 1200,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "queryId",
    "mode",
    "selectedSignalIds",
    "answer",
    "evidenceUsed",
    "assumptions",
    "limitations",
    "suggestedNextQuestion",
    "suggestedMission"
  ],
  "type": "object"
}
