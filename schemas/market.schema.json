{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-atlas.local/schemas/market.schema.json",
  "title": "Signal Atlas Market",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "question",
    "outcomes",
    "resolutionRules",
    "status",
    "tags",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "externalId": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "outcomes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/outcome"
      }
    },
    "resolutionRules": {
      "type": "string",
      "minLength": 1
    },
    "resolutionSource": {
      "type": "string"
    },
    "opensAt": {
      "type": "string",
      "format": "date-time"
    },
    "closesAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvesAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "draft",
        "open",
        "closed",
        "resolved",
        "void"
      ]
    },
    "currentPublicProbabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "resolvedOutcomeId": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "shortLabel"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "shortLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 12
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
