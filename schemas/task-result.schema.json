{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-atlas.local/schemas/task-result.schema.json",
  "title": "Codex Task Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "status",
    "summary",
    "filesChanged",
    "commandsRun",
    "remainingRisks"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "filesChanged": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commandsRun": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        }
      }
    },
    "remainingRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextTask": {
      "type": "string"
    }
  }
}
