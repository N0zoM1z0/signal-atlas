{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-atlas.local/schemas/agent-turn-output.schema.json",
  "title": "Signal Atlas Agent Turn Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentId",
    "missionId",
    "action",
    "publicDialogue",
    "sourceIdsUsed",
    "proposedClaims",
    "proposedSignals",
    "rationale",
    "assumptions",
    "unknowns"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "missionId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "reason"
          ],
          "properties": {
            "type": {
              "const": "wait"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "destinationPlaceId"
          ],
          "properties": {
            "type": {
              "const": "move"
            },
            "destinationPlaceId": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "capability",
            "query"
          ],
          "properties": {
            "type": {
              "const": "investigate"
            },
            "capability": {
              "type": "string"
            },
            "query": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "targetAgentId",
            "signalIds"
          ],
          "properties": {
            "type": {
              "const": "share_signal"
            },
            "targetAgentId": {
              "type": "string"
            },
            "signalIds": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "verb",
            "objective"
          ],
          "properties": {
            "type": {
              "const": "request_mission"
            },
            "verb": {
              "$ref": "#/$defs/missionVerb"
            },
            "objective": {
              "type": "string"
            },
            "destinationPlaceId": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "probabilities"
          ],
          "properties": {
            "type": {
              "const": "update_belief"
            },
            "probabilities": {
              "type": "object",
              "minProperties": 2,
              "additionalProperties": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "uncertainty": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/probabilityRange"
              }
            }
          }
        }
      ]
    },
    "publicDialogue": {
      "type": "string",
      "minLength": 1,
      "maxLength": 360
    },
    "sourceIdsUsed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "proposedClaims": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/proposedClaim"
      }
    },
    "proposedSignals": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/proposedSignal"
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "assumptions": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string"
      }
    },
    "unknowns": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string"
      }
    },
    "suggestedFollowUp": {
      "$ref": "#/$defs/followUp"
    }
  },
  "$defs": {
    "missionVerb": {
      "enum": [
        "investigate",
        "verify",
        "search_history",
        "find_contradiction",
        "compare_sources",
        "observe_conditions",
        "meet_agent",
        "deliver_signal",
        "reassess_forecast",
        "consult_professor"
      ]
    },
    "probabilityRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "low",
        "high"
      ],
      "properties": {
        "low": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "high": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "proposedClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "sourceIds",
        "qualifiers"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "qualifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "proposedSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline",
        "summary",
        "claimIndexes",
        "sourceIds",
        "direction",
        "impactLabel"
      ],
      "properties": {
        "headline": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "claimIndexes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "uniqueItems": true
        },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "direction": {
          "enum": [
            "supports_outcome",
            "opposes_outcome",
            "context"
          ]
        },
        "targetOutcomeId": {
          "type": "string"
        },
        "impactLabel": {
          "enum": [
            "small",
            "medium",
            "large",
            "unknown"
          ]
        }
      }
    },
    "followUp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verb",
        "objective"
      ],
      "properties": {
        "verb": {
          "$ref": "#/$defs/missionVerb"
        },
        "objective": {
          "type": "string"
        },
        "destinationPlaceId": {
          "type": "string"
        }
      }
    }
  }
}
