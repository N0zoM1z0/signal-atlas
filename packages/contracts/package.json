{
  "name": "@signal-atlas/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "check:schemas": "tsx scripts/generate-schemas.ts --check",
    "build": "pnpm generate:schemas && tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
