{
  "name": "@signal-atlas/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "build": "pnpm generate:tokens && tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
